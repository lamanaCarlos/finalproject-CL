# Configuración de Base de Datos
MONGO_URI=mongodb://localhost:27017/marketplace-arte
# Para MongoDB Atlas usar:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/marketplace-arte?retryWrites=true&w=majority

# Configuración del Servidor
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Usuario Administrador Inicial
ADMIN_EMAIL=admin@marketplace.com
ADMIN_PASSWORD=Admin123!

# CDN / Almacenamiento de Imágenes
CDN_URL=https://your-cdn-url.com
# Cloudinary (opcional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Pagos (opcional para futuras fases)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
